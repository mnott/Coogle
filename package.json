{
  "name": "@tekmidian/coogle",
  "version": "0.2.17",
  "description": "Coogle — Google Workspace MCP multiplexer for Claude Code. One persistent daemon, no credential conflicts across multiple sessions.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coogle": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js serve",
    "mcp": "node dist/index.js mcp",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "google-workspace",
    "claude",
    "claude-code",
    "mcp-server",
    "gmail",
    "google-drive",
    "google-calendar",
    "coogle-mcp",
    "daemon",
    "multiplexer"
  ],
  "license": "MIT",
  "author": "Matthias Nott",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnott/Coogle.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@modelcontextprotocol/sdk": "latest"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7"
  }
}
